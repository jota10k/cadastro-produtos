<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cadastro de Produtos</title>

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .container {
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.2);
        width: 350px;
    }

    h2 {
        text-align: center;
    }

    input {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        margin-bottom: 5px;
        border: 1px solid #ccc;
        border-radius: 5px;
        box-sizing: border-box;
    }

    .erro {
        color: red;
        font-size: 14px;
    }

    .sucesso {
        color: green;
        font-size: 14px;
    }

    button {
        width: 100%;
        padding: 10px;
        border: none;
        background-color: green;
        color: white;
        border-radius: 5px;
        cursor: pointer;
        margin-top: 10px;
    }

    button:hover {
        background-color: darkgreen;
    }

    #mensagemFinal {
        margin-top: 15px;
        text-align: center;
        font-weight: bold;
    }
</style>
</head>
<body>

<div class="container">
    <h2>Cadastro de Produtos</h2>

    <label for="produto">Nome do Produto:</label>
    <input type="text" id="produto" placeholder="Digite o nome do produto">
    <div id="msgProduto"></div>

    <label for="preco">Preço:</label>
    <input type="text" id="preco" placeholder="Digite o preço">
    <div id="msgPreco"></div>

    <button onclick="salvarProduto()">Entrar</button>

    <div id="mensagemFinal"></div>
</div>

<script>
const produto = document.getElementById("produto");
const preco = document.getElementById("preco");

produto.addEventListener("input", validarProduto);
preco.addEventListener("input", validarPreco);

function validarProduto() {
    const msgProduto = document.getElementById("msgProduto");

    if (produto.value.trim() === "") {
        msgProduto.textContent = "Preencha o nome do produto.";
        msgProduto.className = "erro";
        return false;
    }

    const somenteLetras = /^[A-Za-zÀ-ÿ\s]+$/;

    if (!somenteLetras.test(produto.value)) {
        msgProduto.textContent =
            "Este campo deve conter apenas letras.";
        msgProduto.className = "erro";
        return false;
    }

    msgProduto.textContent = "Nome do produto válido.";
    msgProduto.className = "sucesso";
    return true;
}

function validarPreco() {
    const msgPreco = document.getElementById("msgPreco");

    if (preco.value.trim() === "") {
        msgPreco.textContent = "Preencha o preço do produto.";
        msgPreco.className = "erro";
        return false;
    }

    const somenteNumeros = /^\d+(\.\d{1,2})?$/;

    if (!somenteNumeros.test(preco.value)) {
        msgPreco.textContent =
            "Este campo deve conter apenas números.";
        msgPreco.className = "erro";
        return false;
    }

    msgPreco.textContent = "Preço válido.";
    msgPreco.className = "sucesso";
    return true;
}

function salvarProduto() {

    const produtoValido = validarProduto();
    const precoValido = validarPreco();

    if (produtoValido && precoValido) {

        document.getElementById("mensagemFinal").textContent =
            "✅ Produto salvo com sucesso!";

        document.getElementById("mensagemFinal").className =
            "sucesso";

        produto.value = "";
        preco.value = "";

        document.getElementById("msgProduto").textContent = "";
        document.getElementById("msgPreco").textContent = "";

    } else {

        document.getElementById("mensagemFinal").textContent =
            "❌ Corrija os erros antes de salvar.";

        document.getElementById("mensagemFinal").className =
            "erro";
    }
}
</script>

</body>
</html>
